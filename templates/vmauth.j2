{{ '## vmauth' }}
{{ '# ' + ansible_managed }}
{{ '# Do not edit manually' }}

{% if lookup('ansible.builtin.vars', 'victoriametrics_service_settings_vmauth',
  default='') not in ['', [], '[]', None] %}
{% for v in lookup('ansible.builtin.vars',
  'victoriametrics_service_settings_vmauth') %}
{% if loop['first'] %}
{{ 'VMAUTH_ARGS=\"' -}}
{% endif %}
{% if v['backend'] is defined and v['backend'] not in ['', [], '[]', None] %}
{% for vb in v['backend'] %}
{%- include 'vm.d/backend_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['config_check_interval'] is defined and
  v['config_check_interval'] not in ['', [], '[]', None] %}
{{ ' --configCheckInterval=\'' + v['config_check_interval'] + '\'' -}}
{% endif %}
{% if v['discover_backend_ips'] is defined and v['discover_backend_ips'] ==
  'true' %}
{{ ' --discoverBackendIPs' -}}
{% endif %}
{% if v['discover_backend_ips_interval'] is defined and
  v['discover_backend_ips_interval'] not in ['', [], '[]', None] %}
{{ ' --discoverBackendIPsInterval=\'' + v['discover_backend_ips_interval'] +
  '\'' -}}
{% endif %}
{%- include 'vm.d/generic_options.j2' -%}
{% if v['fail_timeout'] is defined and v['fail_timeout']
  not in ['', [], '[]', None] %}
{{ ' --failTimeout=\'' + v['fail_timeout'] + '\'' -}}
{% endif %}
{% if v['http'] is defined and v['http'] not in ['', [], '[]', None] %}
{% for vh in v['http'] %}
{%- include 'vm.d/http_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['idle_conn_timeout'] is defined and v['idle_conn_timeout']
  not in ['', [], '[]', None] %}
{{ ' --idleConnTimeout=\'' + v['idle_conn_timeout'] + '\'' -}}
{% endif %}
{%- include 'vm.d/intern_options.j2' -%}
{% if v['load_balancing_policy'] is defined and v['load_balancing_policy'] in
  ['least_loaded', 'first_available'] %}
{{ ' --loadBalancingPolicy=\'' + v['load_balancing_policy'] + '\'' -}}
{% endif %}
{% if v['log_invalid_auth_tokens'] is defined and
  v['log_invalid_auth_tokens'] == 'true' %}
{{ ' --logInvalidAuthTokens' -}}
{% endif %}
{% if v['logger'] is defined and v['logger'] not in ['', [], '[]', None] %}
{% for vl in v['logger'] %}
{%- include 'vm.d/logger_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['max_concurrent_per_user_requests'] is defined and
  v['max_concurrent_per_user_requests'] not in ['', [], '[]', None] %}
{{ ' --maxConcurrentPerUserRequests=\'' ~
  v['max_concurrent_per_user_requests'] ~ '\'' -}}
{% endif %}
{% if v['max_concurrent_requests'] is defined and
  v['max_concurrent_requests'] not in ['', [], '[]', None] %}
{{ ' --maxConcurrentRequests=\'' ~ v['max_concurrent_requests'] ~ '\'' -}}
{% endif %}
{% if v['max_idle_conns_per_backend'] is defined and
  v['max_idle_conns_per_backend'] not in ['', [], '[]', None] %}
{{ ' --maxIdleConnsPerBackend=\'' ~ v['max_idle_conns_per_backend'] ~ '\'' -}}
{% endif %}
{% if v['max_request_body_size_to_retry'] is defined and
  v['max_request_body_size_to_retry'] not in ['', [], '[]', None] %}
{{ ' --maxRequestBodySizeToRetry=\'' ~ v['max_request_body_size_to_retry'] ~
  '\'' -}}
{% endif %}
{%- include 'vm.d/memory_options.j2' -%}
{% if v['metrics'] is defined and v['metrics'] not in ['', [], '[]', None] %}
{% for vm in v['metrics'] %}
{%- include 'vm.d/metrics_options.j2' -%}
{% endfor %}
{% endif %}
{%- include 'vm.d/pprof_options.j2' -%}
{% if v['pushmetrics'] is defined and v['pushmetrics']
  not in ['', [], '[]', None] %}
{% for vp in v['pushmetrics'] %}
{%- include 'vm.d/pushmetrics_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['reload_auth_key'] is defined and v['reload_auth_key']
  not in ['', [], '[]', None] %}
{{ ' --reloadAuthKey=\'' + v['reload_auth_key'] + '\'' -}}
{% endif %}
{% if v['remove_xff_http_header_value'] is defined and
  v['remove_xff_http_header_value'] == 'true' %}
{{ ' --removeXFFHTTPHeaderValue' -}}
{% endif %}
{% if v['response_timeout'] is defined and v['response_timeout']
  not in ['', [], '[]', None] %}
{{ ' --responseTimeout=\'' + v['response_timeout'] + '\'' -}}
{% endif %}
{% if v['retry_status_codes'] is defined and v['retry_status_codes']
  not in ['', [], '[]', None] %}
{% if v['retry_status_codes'] is string %}
{{ ' --retryStatusCodes=' + v['retry_status_codes'] -}}
{% elif v['retry_status_codes'] is sequence %}
{{ ' --retryStatusCodes=\'' + (v['retry_status_codes'] |
  ansible.builtin.join(",")) + '\'' -}}
{% endif %}
{% endif %}
{% if v['tls'] is defined and v['tls'] not in ['', [], '[]', None] %}
{% for vt in v['tls'] %}
{%- include 'vm.d/tls_options.j2' -%}
{% endfor %}
{% endif %}
{% if loop['last'] %}
{{- '\"' }}
{% endif %}
{% endfor %}
{% else %}
{{ 'VMAUTH_ARGS=\"\"' }}
{% endif %}
