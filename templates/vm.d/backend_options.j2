{% if vb['tls_ca_file'] is defined and vb['tls_ca_file']
  not in ['', [], '[]', None] %}
{{ ' --backend.TLSCAFile=\'' + vb['tls_ca_file'] + '\'' -}}
{% endif %}
{% if vb['tls_cert_file'] is defined and vb['tls_cert_file']
  not in ['', [], '[]', None] %}
{{ ' --backend.TLSCertFile=\'' + vb['tls_cert_file'] + '\'' -}}
{% endif %}
{% if vb['tls_key_file'] is defined and vb['tls_key_file']
  not in ['', [], '[]', None] %}
{{ ' --backend.TLSKeyFile=\'' + vb['tls_key_file'] + '\'' -}}
{% endif %}
{% if vb['tls_server_name'] is defined and vb['tls_server_name']
  not in ['', [], '[]', None] %}
{{ ' --backend.TLSServerName=\'' + vb['tls_server_name'] + '\'' -}}
{% endif %}
{% if vb['tls_insecure_skip_verify'] is defined and
  vb['tls_insecure_skip_verify'] == 'true' %}
{{ ' --backend.tlsInsecureSkipVerify' -}}
{% endif %}
