{{ '## vminsert' }}
{{ '# ' + ansible_managed }}
{{ '# Do not edit manually' }}

{% if lookup('ansible.builtin.vars',
  'victoriametrics_service_settings_vminsert', default='')
  not in ['', [], '[]', None] %}
{% for v in lookup('ansible.builtin.vars',
  'victoriametrics_service_settings_vminsert') %}
{% if loop['first'] %}
{{ 'VMINSERT_ARGS=\"' -}}
{% endif %}
{%- include 'vm.d/cache_options.j2' -%}
{% if v['cluster_native'] is defined and v['cluster_native']
  not in ['', [], '[]', None] %}
{% for vcn in v['cluster_native'] %}
{%- include 'vm.d/cluster_native_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['csv_trim_timestamp'] is defined and v['csv_trim_timestamp']
  not in ['', [], '[]', None] %}
{{ ' --csvTrimTimestamp=\'' + v['csv_trim_timestamp'] + '\'' -}}
{% endif %}
{% if v['datadog'] is defined and v['datadog'] not in ['', [], '[]', None] %}
{% for vd in v['datadog'] %}
{% if vd['max_insert_request_size'] is defined and
  vd['max_insert_request_size'] not in ['', [], '[]', None] %}
{{ ' --datadog.maxInsertRequestSize=\'' + vd['max_insert_request_size'] +
  '\'' -}}
{% endif %}
{% if vd['sanitize_metric_name'] is defined and
  vd['sanitize_metric_name'] == 'true' %}
{{ ' --datadog.sanitizeMetricName' -}}
{% endif %}
{% endfor %}
{% endif %}
{%- include 'vm.d/generic_options.j2' -%}
{% if v['disable_rerouting'] is defined and v['disable_rerouting'] == 'true' %}
{{ ' --disableRerouting' -}}
{% endif %}
{% if v['disable_rerouting_on_unavailable'] is defined and
  v['disable_rerouting_on_unavailable'] == 'true' %}
{{ ' --disableReroutingOnUnavailable' -}}
{% endif %}
{% if v['drop_samples_on_overload'] is defined and
  v['drop_samples_on_overload'] == 'true' %}
{{ ' --dropSamplesOnOverload' -}}
{% endif %}
{% if v['graphite'] is defined and v['graphite'] not in ['', [], '[]', None] %}
{% for vg in v['graphite'] %}
{%- include 'vm.d/graphite_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['http'] is defined and v['http'] not in ['', [], '[]', None] %}
{% for vh in v['http'] %}
{%- include 'vm.d/http_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['import_max_line_len'] is defined and v['import_max_line_len']
  not in ['', [], '[]', None] %}
{{ ' --import.maxLineLen=\'' + v['import_max_line_len'] + '\'' -}}
{% endif %}
{% if v['influxdb'] is defined and v['influxdb'] not in ['', [], '[]', None] %}
{% for vi in v['influxdb'] %}
{%- include 'vm.d/influxdb_options.j2' -%}
{% endfor %}
{% endif %}
{%- include 'vm.d/intern_options.j2' -%}
{% if v['logger'] is defined and v['logger'] not in ['', [], '[]', None] %}
{% for vl in v['logger'] %}
{%- include 'vm.d/logger_options.j2' -%}
{% endfor %}
{% endif %}
{%- include 'vm.d/memory_options.j2' -%}
{% if v['max_insert_request_size'] is defined and
  v['max_insert_request_size'] not in ['', [], '[]', None] %}
{{ ' --maxInsertRequestSize=\'' + v['max_insert_request_size'] + '\'' -}}
{% endif %}
{% if v['max_label_name_len'] is defined and
  v['max_label_name_len'] not in ['', [], '[]', None] %}
{{ ' --maxLabelNameLen=\'' ~ v['max_label_name_len'] ~ '\'' -}}
{% endif %}
{% if v['max_label_value_len'] is defined and
  v['max_label_value_len'] not in ['', [], '[]', None] %}
{{ ' --maxLabelValueLen=\'' ~ v['max_label_value_len'] ~ '\'' -}}
{% endif %}
{% if v['max_labels_per_timeseries'] is defined and
  v['max_labels_per_timeseries'] not in ['', [], '[]', None] %}
{{ ' --maxLabelsPerTimeseries=\'' ~ v['max_labels_per_timeseries'] ~ '\'' -}}
{% endif %}
{% if v['metrics'] is defined and v['metrics'] not in ['', [], '[]', None] %}
{% for vm in v['metrics'] %}
{%- include 'vm.d/metrics_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['newrelic_max_insert_request_size'] is defined and
  v['newrelic_max_insert_request_size'] not in ['', [], '[]', None] %}
{{ ' --newrelic.maxInsertRequestSize=\'' +
  v['newrelic_max_insert_request_size'] + '\'' -}}
{% endif %}
{% if v['opentelemetry_use_prometheus_naming'] is defined and
  v['opentelemetry_use_prometheus_naming'] == 'true' %}
{{ ' --opentelemetry.usePrometheusNaming' -}}
{% endif %}
{% if v['opentsdb'] is defined and v['opentsdb'] not in ['', [], '[]', None] %}
{% for vo in v['opentsdb'] %}
{%- include 'vm.d/opentsdb_options.j2' -%}
{% endfor %}
{% endif %}
{%- include 'vm.d/pprof_options.j2' -%}
{% if v['pushmetrics'] is defined and v['pushmetrics']
  not in ['', [], '[]', None] %}
{% for vp in v['pushmetrics'] %}
{%- include 'vm.d/pushmetrics_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['relabel_config_check_interval'] is defined and
  v['relabel_config_check_interval'] not in ['', [], '[]', None] %}
{{ ' --relabelConfigCheckInterval=\'' + v['relabel_config_check_interval'] +
  '\'' -}}
{% endif %}
{% if v['replication_factor'] is defined and v['replication_factor']
  not in ['', [], '[]', None] %}
{{ ' --replicationFactor=\'' ~ v['replication_factor'] ~ '\'' -}}
{% endif %}
{%- include 'vm.d/rpc_options.j2' -%}
{% if v['sort_labels'] is defined and v['sort_labels'] == 'true' %}
{{ ' --sortLabels' -}}
{% endif %}
{%- include 'vm.d/storage_options.j2' -%}
{% if v['tls'] is defined and v['tls'] not in ['', [], '[]', None] %}
{% for vt in v['tls'] %}
{%- include 'vm.d/tls_options.j2' -%}
{% endfor %}
{% endif %}
{% if v['use_prom_compatible_naming'] is defined and
  v['use_prom_compatible_naming'] == 'true' %}
{{ ' --usePromCompatibleNaming' -}}
{% endif %}
{% if loop['last'] %}
{{- '\"' }}
{% endif %}
{% endfor %}
{% else %}
{{ 'VMINSERT_ARGS=\"\"' }}
{% endif %}
